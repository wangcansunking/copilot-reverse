# HTTP edge-case e2e image for copilot-reverse.
#
# Boots the REAL supervisor (which forks the REAL worker) and drives them over HTTP — exercising the
# error paths, supervision lifecycle, and crash-guard regressions a client/TUI would hit. Most cases
# reject before any upstream call, so a token is OPTIONAL (only the golden round-trips need one).
#
# Build: docker build -f e2e/docker/Dockerfile.http -t copilot-reverse-http-e2e .
# Run:   docker run --rm copilot-reverse-http-e2e            # token-free edge cases
#        docker run --rm -v "$HOME/.copilot-reverse/creds.json:/run/secrets/creds.json:ro" copilot-reverse-http-e2e
#
# node:20 (better-sqlite3 native build needs the toolchain).
FROM node:20
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci
COPY tsconfig.json ./
COPY scripts ./scripts
COPY src ./src
COPY e2e ./e2e
RUN npm run build
ENTRYPOINT ["node", "e2e/docker/http-e2e.mjs"]
